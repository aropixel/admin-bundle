{% extends '@AropixelAdmin/base.html.twig' %}

{% block theme_javascripts %}
{% endblock %}

{% block body_content %}
	<div id="app">
		<section class="section">
			<div class="container mt-5">
				<div class="row">
					<div class="col-12 col-sm-8 offset-sm-2 col-md-6 offset-md-3 col-lg-6 offset-lg-3">
						<div class="login-brand">
							<img src="{{ asset('bundles/aropixeladmin/img/logo.png') }}" alt="{{ admin_client.name }}" width="180">
						</div>

						{{ form_start(form) }}
						<div class="card mt-5">
							<div class="card-header d-flex flex-column justify-content-start align-items-start">
								<h4 class="mb-1">{% trans %}reset.request.title{% endtrans %}</h4>
								<p class="mb-0">{% trans %}reset.request.subtitle{% endtrans %}</p>
							</div>

							<div class="card-body">

								<div class="mt-4 mb-4">
									<label for="email">{% trans %}reset.request.form{% endtrans %}</label>
									{{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
								</div>
								{% if not_found %}<div class="alert alert-danger">{% trans %}reset.request.alert.not_found{% endtrans %}</div>{% endif %}

							</div>
						</div>
						<div class="d-flex justify-content-center">
							<button type="submit" class="btn btn-primary btn-lg btn-block" tabindex="4">{% trans %}reset.request.submit{% endtrans %}</button>
						</div>
						{{ form_end(form) }}

						<br /><br /><br />
						<div class="simple-footer">
							Copyright &copy; {{ admin_client.name }} {{ "now"|date('Y') }}
						</div>
					</div>
				</div>
			</div>
		</section>
	</div>
{% endblock %}
