{% extends '@AropixelAdmin/base.html.twig' %}

{% block body_content %}
	<div id="app">

		<section class="section">

			<div class="container mt-5">

				<div class="row">

					<div class="col-12 col-sm-8 offset-sm-2 col-md-6 offset-md-3 col-lg-6 offset-lg-3">

						<div class="login-brand">
							<img src="{{ asset('bundles/aropixeladmin/img/logo.png') }}" alt="{{ admin_client.name }}" width="180">
						</div>

						{{ form_start(form) }}

						<div class="card mt-5">

							<div class="card-header"><h4>{% trans %}activation.choose_password.title{% endtrans %}</h4></div>

							<div class="card-body">

								{% if error %}
									<div class="alert alert-danger">
										{{ error }}
									</div>
								{% endif %}


								<div class="form-group">
									{{ form_row(form.password.first, {'attr': {'class': 'form-control', 'data-gdpr': 'true'}}) }}
								</div>

								<div class="form-group">
									{{ form_row(form.password.second, {'attr': {'class': 'form-control'}}) }}
								</div>

							</div>
						</div>
						<div class="d-flex justify-content-center">
							<button type="submit" class="btn btn-primary btn-lg btn-block" tabindex="4">{% trans %}activation.choose_password.submit{% endtrans %}</button>
						</div>

						{{ form_end(form) }}

						<div class="simple-footer mt-5">
							Copyright &copy; {{ admin_client.name }} {{ "now"|date('Y') }}
						</div>

					</div>

				</div>

			</div>

		</section>

	</div>
{% endblock %}